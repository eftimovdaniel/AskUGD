# ==== LLM (OpenAI-компатибилен API) — ЗАДОЛЖИТЕЛНО ====
# Продукција (OpenAI):
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Развој (Groq, бесплатно) — одкоментирај ги овие 3 наместо горните:
# LLM_API_KEY=gsk_...
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# ==== Qdrant (default: локален docker) ====
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=             # само за Qdrant Cloud
QDRANT_COLLECTION=askugd

# ==== Redis — ЗАДОЛЖИТЕЛНО за повеќе workers (gunicorn -w 2+) ====
# Споделува историја + rate limits меѓу процесите.
# REDIS_URL=redis://localhost:6379/0

# ==== Продукциска безбедност ====
# CORS_ORIGINS=https://www.ugd.edu.mk
# API_ACCESS_KEY=             # ако е поставен, widget-от праќа X-API-Key header
RATE_LIMIT=20                 # барања/мин по СЕСИЈА
RATE_LIMIT_IP=300             # барања/мин по IP (кампус NAT — повисок!)
# TRUST_PROXY_HEADERS=true    # САМО ако си зад nginx/caddy што поставува
                              # X-Forwarded-For — инаку клиенти можат да лажираат IP

# ==== Тјунирање (опционално) ====
# MAX_ANSWER_TOKENS=1200
# TOP_K=5
# CANDIDATE_K=20
# RERANK_THRESHOLD=0.1
# MAX_RETRIEVAL_ITERATIONS=3
